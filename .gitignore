# ── Python ────────────────────────────────────────────────────────────────────
*.pyc
__pycache__/
*.egg-info/

# ── Local secrets / env ───────────────────────────────────────────────────────
backend/.env
.env

# ── Local SQLite database (development only) ────────────────────────────────
74sim_local.db
74sim_local.db-shm
74sim_local.db-wal

# ── Virtualenvs ──────────────────────────────────────────────────────────────
backend/.venv/
.venv/
.venv-chipadder/

# ── Uploaded user content (ephemeral on App Platform; never commit) ──────────
reports/
submissions/

# ── Editor / OS noise ────────────────────────────────────────────────────────
.DS_Store
.claude/worktrees/relaxed-ellis/

# ── Tauri build output ───────────────────────────────────────────────────────
src-tauri/target/
dist-app/

# ── Desktop installer cache (uploaded to Spaces, never committed) ────────────
# Per-platform buildDesktop*.sh scripts cache their build output here for the
# uploader; the bucket is the authoritative store. Keep .gitkeep so the dir
# exists for the LocalStorage fallback in dev mode.
releases/*
!releases/.gitkeep

desktopVersionReference/

.pdf

# ── claudChipAdder per-agent transcripts (local only) ────────────────────────
claudChipAdder-logs/
