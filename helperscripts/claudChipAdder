#!/usr/bin/env python3
"""Spawn parallel Claude agents to implement the next missing chips in 74Sim.

Reads the importance-ordered work list in chips-to-add.md, picks the top N
not-yet-done chips, and runs one Opus agent per chip in parallel. Each agent
implements its chip, verifies it, and checks its line off in chips-to-add.md.

Runs on your Claude Code subscription (the SDK uses the logged-in `claude` CLI
auth when ANTHROPIC_API_KEY is unset) — so there is no per-token dollar cost to
report; usage counts against your plan's limits instead.

Resilience: if the account hits a usage limit, agents don't fail — they pause,
wait for the limit to reset, and RESUME the same session (full prior context),
so in-progress work is not lost. A heartbeat every HEARTBEAT_SEC shows how many
agents are working, what each is doing, and the 5-hour usage % when known.

Agents run with permissions bypassed (unattended). If an agent hits a decision
it genuinely can't resolve, it can call the `ask_user` tool, which prompts you
here; if you don't start typing within 15 seconds it tells the agent to figure
it out on its own.

Usage:
    pip install claude-agent-sdk        # into a clean venv (see note below)
    python3 claudChipAdder              # or ./claudChipAdder

Note on the venv: do NOT install into backend/.venv — its pip's vendored
resolvelib is broken (ImportError: RequirementInformation). Use a fresh venv,
e.g.  python3 -m venv .venv-chipadder && .venv-chipadder/bin/pip install claude-agent-sdk
then run with  .venv-chipadder/bin/python3 claudChipAdder
"""

import asyncio
import re
import select
import sys
import time
from datetime import datetime
from pathlib import Path

try:
    import termios
    import tty
    _HAVE_TTY = True
except ImportError:  # non-unix; fall back to plain line input
    _HAVE_TTY = False

try:
    from claude_agent_sdk import (
        AssistantMessage,
        ClaudeAgentOptions,
        ClaudeSDKClient,
        RateLimitEvent,
        ResultMessage,
        TextBlock,
        ThinkingBlock,
        ToolUseBlock,
        create_sdk_mcp_server,
        tool,
    )
except ImportError:
    sys.exit("Missing dependency. Run: pip install claude-agent-sdk")

REPO_ROOT = Path(__file__).resolve().parent
LIST_PATH = REPO_ROOT / "chips-to-add.md"
CHIPS_DIR = REPO_ROOT / "js" / "chips"
LOG_DIR = REPO_ROOT / "claudChipAdder-logs"

MODEL = "claude-opus-4-8"
NUM_AGENTS = 10
MAX_ERROR_RETRIES = 3
ASK_TIMEOUT_SEC = 15.0
HEARTBEAT_SEC = 10          # how often the "N agents working" status prints
RATE_LIMIT_POLL_SEC = 60     # fallback wait when a limit has no reset timestamp (normal mode)
FIVE_HOUR_SEC = 5 * 3600     # superAuto fallback wait when a limit has no reset timestamp

# superAuto: run the ENTIRE backlog unattended. Keep grabbing the next NUM_AGENTS
# chips until chips-to-add.md is empty, and when usage runs out with no reported
# reset time, wait the full 5-hour window for it to come back, then continue.
superAuto = True

# Only one agent may own the terminal prompt at a time (agents run concurrently).
ASK_LOCK = asyncio.Lock()

AUTO_PROCEED_MSG = (
    "No response from the operator within 15 seconds — they are running this "
    "unattended with minimal effort and are not watching. Figure it out "
    "yourself: pick the most reasonable option based on the datasheet and the "
    "repo's existing conventions, and keep going. Don't ask again unless you "
    "are genuinely, hard blocked."
)

# Matches:  - [ ] CD4047 — function — primitive   (em-dash separated)
# IDs are either CMOS-4000 parts (CD####) to ADD as new chips, or 74-series
# parts (74x###) that already exist as stubs and get UPGRADED in place.
ROW_RE = re.compile(r"^- \[(?P<done>[ xX])\]\s+(?P<id>(?:CD\d{4,5}|74x\d{3,5}))\s+—\s+(?P<rest>.*)$")


# ── Monitoring ───────────────────────────────────────────────────────────────

class Monitor:
    """Shared status board for all agents plus a periodic heartbeat printer."""

    ACTIVE = ("thinking", "working", "waiting")

    def __init__(self):
        self.activity = {}          # label -> (status, short text)
        self.last_rate = None       # most recent RateLimitInfo seen
        self.five_hour_util = None  # 0.0-1.0, only the five_hour window
        self.prompting = False      # True while an ask_user prompt owns the TTY
        self._stop = asyncio.Event()

    def update(self, label, status, text=""):
        self.activity[label] = (status, text)

    def note_rate(self, info):
        self.last_rate = info
        if info.rate_limit_type == "five_hour" and info.utilization is not None:
            self.five_hour_util = info.utilization

    def print_heartbeat(self):
        active = {l: v for l, v in self.activity.items() if v[0] in self.ACTIVE}
        if not active:
            return
        ts = datetime.now().strftime("%H:%M:%S")
        head = f"[{ts}] {len(active)} agent(s) working"
        if self.five_hour_util is not None:
            head += f"  ·  5h usage: {self.five_hour_util * 100:.0f}%"
        elif self.last_rate is not None and self.last_rate.utilization is not None:
            head += f"  ·  {self.last_rate.rate_limit_type} usage: {self.last_rate.utilization * 100:.0f}%"
        lines = [head]
        for label, (status, text) in active.items():
            lines.append(f"    {label:<8} {status:<8} {text}")
        print("\n".join(lines), flush=True)

    async def run(self):
        while not self._stop.is_set():
            try:
                await asyncio.wait_for(self._stop.wait(), timeout=HEARTBEAT_SEC)
            except asyncio.TimeoutError:
                if not self.prompting:  # don't scribble over an ask_user prompt
                    self.print_heartbeat()

    def stop(self):
        self._stop.set()


def _short(text, n=90):
    text = " ".join((text or "").split())
    return text[:n] + ("…" if len(text) > n else "")


def _tool_summary(block):
    inp = block.input or {}
    for key in ("file_path", "path", "command", "pattern", "url", "question"):
        if key in inp:
            return f"{block.name}: {_short(str(inp[key]), 64)}"
    return block.name


def _to_epoch_seconds(ts):
    if not ts:
        return None
    ts = float(ts)
    return ts / 1000.0 if ts > 1e12 else ts  # tolerate ms timestamps


def _is_rate_limit_error(result):
    if result is None or not getattr(result, "is_error", False):
        return False
    if getattr(result, "api_error_status", None) == 429:
        return True
    blob = (" ".join(result.errors or []) + " " + (getattr(result, "subtype", "") or "")).lower()
    return "rate limit" in blob or "rate_limit" in blob or "429" in blob


# ── Work list ────────────────────────────────────────────────────────────────

def load_pending_chips():
    """Top-to-bottom (= importance order) not-yet-checked chips in chips-to-add.md."""
    if not LIST_PATH.exists():
        sys.exit(f"Missing {LIST_PATH.name}. It's the work list this script reads.")
    chips = []
    for line in LIST_PATH.read_text().splitlines():
        m = ROW_RE.match(line.strip())
        if not m or m.group("done").strip().lower() == "x":
            continue
        func, _, prim = m.group("rest").partition("—")
        chips.append(
            {
                "id": m.group("id"),
                "number": m.group("id")[2:],
                "function": func.strip(),
                "notes": prim.strip() or "n/a",
            }
        )
    return chips


def next_block_numbers(n):
    existing = [
        int(m.group(1))
        for p in CHIPS_DIR.glob("chips*.js")
        if (m := re.fullmatch(r"chips(\d+)\.js", p.name))
    ]
    start = max(existing, default=0) + 1
    return list(range(start, start + n))


# ── ask_user tool ────────────────────────────────────────────────────────────

def _blocking_ask(label, question):
    """Prompt on the real terminal. Return the typed answer, or None if the
    operator doesn't start typing within ASK_TIMEOUT_SEC. Blocking — call via
    run_in_executor so the other agents keep working."""
    border = "═" * 72
    sys.stdout.write(
        f"\n{border}\n[{label}] the agent is asking you a question:\n\n"
        f"  {question}\n\n"
        f"  (answer + Enter within {int(ASK_TIMEOUT_SEC)}s, "
        f"or it proceeds on its own)\n> "
    )
    sys.stdout.flush()

    if not _HAVE_TTY or not sys.stdin or not sys.stdin.isatty():
        # No real TTY: wait for a whole line, timing out the same way.
        ready, _, _ = select.select([sys.stdin], [], [], ASK_TIMEOUT_SEC)
        return sys.stdin.readline().strip() if ready else None

    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setcbreak(fd)  # so we can see the FIRST keystroke, not wait for Enter
        ready, _, _ = select.select([sys.stdin], [], [], ASK_TIMEOUT_SEC)
        if not ready:
            return None  # never started typing
        first = sys.stdin.read(1)
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)

    if first in ("\n", "\r"):
        return ""  # started typing but submitted empty
    sys.stdout.write(first)  # echo the char cbreak swallowed
    sys.stdout.flush()
    rest = sys.stdin.readline()
    return (first + rest).strip()


def make_ask_server(label, monitor):
    """Per-agent in-process MCP server exposing one tool: ask_user."""

    @tool(
        "ask_user",
        "Ask the human operator a question when you hit a decision you cannot "
        "resolve yourself (e.g. an ambiguous datasheet, two valid pinouts). "
        "Returns their answer, or — if they don't respond within 15 seconds — "
        "an instruction to proceed on your own. Use sparingly.",
        {"question": str},
    )
    async def ask_user(args):
        question = (args.get("question") or "").strip() or "(no question text)"
        async with ASK_LOCK:
            monitor.update(label, "waiting", "asking you a question")
            monitor.prompting = True
            loop = asyncio.get_running_loop()
            try:
                answer = await loop.run_in_executor(None, _blocking_ask, label, question)
            finally:
                monitor.prompting = False
        if answer:
            print(f"[{label}] operator answered; resuming", flush=True)
            return {"content": [{"type": "text", "text": f"Operator answered: {answer}"}]}
        print(f"[{label}] no answer in {int(ASK_TIMEOUT_SEC)}s -> told agent to proceed on its own", flush=True)
        return {"content": [{"type": "text", "text": AUTO_PROCEED_MSG}]}

    return create_sdk_mcp_server("ask", "1.0.0", [ask_user])


