def build_retry_prompt(chip, result):
    error_detail = "\n".join(getattr(result, "errors", None) or [str(result)])
    return f"""The previous attempt on {chip['id']} ended in an error:

{error_detail}

I'm running this unattended on purpose and putting in minimal effort on my end —
I'm not going to debug this for you. Figure out the root cause yourself, fix it,
and keep going until {chip['id']}'s docs are improved, verified, and checked off
in chips-to-improve.md. Don't ask me anything else."""


def build_resume_prompt(chip):
    return (
        f"We were paused because the account hit its usage limit; it has now "
        f"reset. Continue exactly where you left off on {chip['id']}. First check "
        f"what you'd already done (datasheet read, pinout verified, docs edited, "
        f"verification run) so you don't duplicate work, then finish: improve the "
        f"docs, verify with the js/debug harness, and check {chip['id']} off in "
        f"chips-to-improve.md. Do not start over."
    )


# ── Agent driver ─────────────────────────────────────────────────────────────

async def drain(client, log_file, monitor, label):
    """Consume one response turn. Log detail, feed the monitor, and return
    (ResultMessage, rate_limit_reset_at) where reset_at is set only if the turn
    was hard-rejected by a usage limit."""
    result = None
    rl_reset_at = None
    async for message in client.receive_response():
        if isinstance(message, AssistantMessage):
            for block in message.content:
                if isinstance(block, TextBlock):
                    log_file.write(block.text + "\n")
                    if block.text.strip():
                        monitor.update(label, "working", _short(block.text))
                elif isinstance(block, ThinkingBlock):
                    log_file.write("[thinking] " + block.thinking + "\n")
                    monitor.update(label, "thinking", _short(block.thinking))
                elif isinstance(block, ToolUseBlock):
                    log_file.write(f"[tool] {block.name} {block.input}\n")
                    monitor.update(label, "working", _tool_summary(block))
            log_file.flush()
        elif isinstance(message, RateLimitEvent):
            info = message.rate_limit_info
            monitor.note_rate(info)
            log_file.write(
                f"[rate-limit] status={info.status} type={info.rate_limit_type} "
                f"util={info.utilization} resets_at={info.resets_at}\n"
            )
            log_file.flush()
            if info.status == "rejected":
                rl_reset_at = info.resets_at or rl_reset_at
        elif isinstance(message, ResultMessage):
            result = message
    return result, rl_reset_at


async def wait_for_reset(monitor, label, reset_at):
    """Sleep until a usage limit resets, updating the heartbeat with a countdown.
    Progress is preserved — the caller resumes the same session afterward."""
    reset_at = _to_epoch_seconds(reset_at)
    now = time.time()
    if reset_at and reset_at > now:
        target = reset_at + 5                     # honor the reported reset (may be sooner than 5h)
    elif superAuto:
        target = now + FIVE_HOUR_SEC              # no timestamp: wait the full 5h window
    else:
        target = now + RATE_LIMIT_POLL_SEC        # no timestamp: poll again shortly
    print(f"[{label}] usage limit hit — pausing ~{int(target - now)}s, will resume (progress saved)", flush=True)
    while True:
        remaining = target - time.time()
        if remaining <= 0:
            break
        mins, secs = divmod(int(remaining), 60)
        monitor.update(label, "waiting", f"usage limit — resuming in {mins}m{secs:02d}s (progress saved)")
        await asyncio.sleep(min(15, remaining))
    monitor.update(label, "working", "resuming after limit reset")


async def improve_chip(chip, monitor):
    label = chip["id"]
    LOG_DIR.mkdir(exist_ok=True)
    monitor.update(label, "working", "starting")
    print(f"[{label}] starting (log: claudChipImprover-logs/{label}.log)", flush=True)

    session_id = None
    sent_initial = False
    last_was_rl = False
    error_retries = 0
    result = None

    with open(LOG_DIR / f"{label}.log", "w") as log_file:
        while True:
            options = ClaudeAgentOptions(
                cwd=str(REPO_ROOT),
                model=MODEL,
                permission_mode="bypassPermissions",
                mcp_servers={"ask": make_ask_server(label, monitor)},
                resume=session_id,  # None first time; resumes prior context after a pause
            )
            if not sent_initial:
                prompt = build_prompt(chip)
            elif last_was_rl:
                prompt = build_resume_prompt(chip)
            else:
                prompt = build_retry_prompt(chip, result)

            try:
                async with ClaudeSDKClient(options=options) as client:
                    await client.query(prompt)
                    result, rl_reset_at = await drain(client, log_file, monitor, label)
                sent_initial = True
                if result is not None and getattr(result, "session_id", None):
                    session_id = result.session_id
            except Exception as exc:
                log_file.write(f"[exception] {exc!r}\n")
                log_file.flush()
                # If a hard usage limit was just seen, treat the crash as a pause.
                if monitor.last_rate is not None and monitor.last_rate.status == "rejected":
                    last_was_rl = True
                    await wait_for_reset(monitor, label, monitor.last_rate.resets_at)
                    continue
                monitor.update(label, "failed", repr(exc))
                print(f"[{label}] crashed: {exc!r}", flush=True)
                return chip, False, repr(exc)

            # Usage limit -> wait for reset and RESUME (progress kept, no retry burned).
            if rl_reset_at or _is_rate_limit_error(result):
                last_was_rl = True
                fallback = monitor.last_rate.resets_at if monitor.last_rate else None
                await wait_for_reset(monitor, label, rl_reset_at or fallback)
                continue

            # Hard error -> burn a retry, feeding the error back in.
            if result is not None and getattr(result, "is_error", False):
                if error_retries < MAX_ERROR_RETRIES:
                    error_retries += 1
                    last_was_rl = False
                    print(f"[{label}] attempt {error_retries} failed ({result.subtype}), sending error back", flush=True)
                    monitor.update(label, "working", f"error retry {error_retries}")
                    continue
                break  # out of retries

            break  # success

    ok = result is not None and not getattr(result, "is_error", False)
    monitor.update(label, "done" if ok else "failed", "")
    print(f"[{label}] {'done' if ok else 'gave up'}", flush=True)
    return chip, ok, result


async def run_batch(selected, monitor):
    print("\nBatch: " + ", ".join(c["id"] for c in selected), flush=True)
    return await asyncio.gather(
        *(improve_chip(chip, monitor) for chip in selected)
    )


async def main():
    mode = "superAuto — grinding the whole backlog" if superAuto else "single batch"
    print(f"Mode: {mode}. Heartbeat every {HEARTBEAT_SEC}s.")
    print("Usage limits pause-and-resume (progress saved), not fail.")
    print("No two agents touch the same chips*.js file at once.")

    id_file = build_id_file_map()
    monitor = Monitor()
    heartbeat = asyncio.create_task(monitor.run())
    all_results = []
    processed = set()  # chips attempted this run (success or fail) — never reselect

    try:
        while True:
            pending = [c for c in load_pending_chips() if c["id"] not in processed]
            if not pending:
                break
            selected = select_batch(pending, id_file, NUM_AGENTS)
            print(f"\n({len(pending)} pending; taking {len(selected)} this batch, "
                  f"one per file, by importance.)")
            results = await run_batch(selected, monitor)
            all_results.extend(results)
            processed.update(chip["id"] for chip, _ok, _r in results)
            if not superAuto:
                break  # one batch only
    finally:
        monitor.stop()
        await heartbeat

    print("\n=== Summary ===")
    if not all_results:
        print("No unchecked chips left in chips-to-improve.md. Nothing to do.")
    for chip, ok, _result in all_results:
        print(f"{chip['id']}: {'OK' if ok else 'FAILED'}")
    if superAuto and all_results:
        print(f"\nBacklog now: {len(load_pending_chips())} chip(s) still unchecked in chips-to-improve.md.")


if __name__ == "__main__":
    asyncio.run(main())
